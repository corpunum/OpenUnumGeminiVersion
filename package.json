{
  "name": "openunum",
  "version": "0.1.0",
  "description": "Minimalist, high-performance AI assistant for Linux",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun run src/tests/run.ts",
    "e2e:webui": "bun test ./tests/e2e/phase0.e2e.ts",
    "e2e:model-catalog": "bun test ./tests/e2e/phase1.model-catalog.e2e.ts",
    "e2e:webui-contract": "bun test ./tests/e2e/phase2.webui-contract.e2e.ts",
    "e2e": "bun test ./tests/e2e/phase0.e2e.ts ./tests/e2e/phase1.model-catalog.e2e.ts ./tests/e2e/phase2.webui-contract.e2e.ts",
    "test:all": "bun run src/tests/run.ts && bun run e2e"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "ajv": "^8.12.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.21.1",
    "playwright": "^1.42.1",
    "sqlite-vec": "^0.1.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
